# TestForge Environment Variables — Copy to .env and fill in values
# ⚠️  NEVER commit .env to version control

JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=user@company.com
JIRA_API_TOKEN=ATATT...

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
GROQ_API_KEY=gsk_...

# Required for Vercel / Cloud Deployment
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJ...           # Anon/public JWT key
SUPABASE_SERVICE_KEY=eyJ...   # Service role key (for admin user creation/deletion)

# Set to true to bypass auth during local development (never use in production)
# AUTH_DISABLED=true
